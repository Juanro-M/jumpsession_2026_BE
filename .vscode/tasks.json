{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "kill-port",
            "command": "powershell",
            "type": "process",
            "args": [
                "-Command",
                "Stop-Process -Name 'Accounting Settle-Up System' -Force -ErrorAction SilentlyContinue; Get-NetTCPConnection -LocalPort 5108 -ErrorAction SilentlyContinue | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force -ErrorAction SilentlyContinue }"
            ]
        },
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "dependsOn": "kill-port",
            "args": [
                "build",
                "${workspaceFolder}/Accounting Settle-Up System/Accounting Settle-Up System.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/Accounting Settle-Up System/Accounting Settle-Up System.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch",
            "command": "dotnet",
            "type": "process",
            "dependsOn": "kill-port",
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/Accounting Settle-Up System/Accounting Settle-Up System.csproj"
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}